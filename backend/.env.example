DATABASE_URL=postgresql://nutriboard:nutriboard@localhost:5432/nutriboard?schema=public
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Separate key for encrypting OAuth tokens at rest (falls back to JWT_SECRET if unset)
ENCRYPTION_KEY=change-me-to-another-long-random-string
# Number of proxy hops your infra adds in front of the app (for correct client IP)
TRUST_PROXY=1
CORS_ORIGIN=http://localhost:5173
ADMIN_EMAILS=a.youssef@salla.sa
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Device-sync OAuth (register apps to enable) ----
OAUTH_REDIRECT_BASE=http://localhost:4000
FRONTEND_URL=http://localhost:5173
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
