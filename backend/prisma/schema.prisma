// NutriBoard data model
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  male
  female
}

enum Goal {
  cut
  recomp
  maintain
  bulk
}

enum MealType {
  Breakfast
  Lunch
  Dinner
  Snack
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      Profile?
  meals        Meal[]
  waterLogs    WaterLog[]
  weightLogs   WeightLog[]
  habits       Habit[]
  habitLogs    HabitLog[]
  chatMessages ChatMessage[]
  changes      ChangeHistory[]
}

model Profile {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  sex           Sex     @default(male)
  age           Int     @default(30)
  weightKg      Float   @default(78)
  heightCm      Float   @default(178)
  activity      Float   @default(1.55) // Mifflin activity multiplier
  goal          Goal    @default(maintain)

  dietType      String  @default("omnivore")
  allergies     String  @default("")
  dislikes      String  @default("")

  wakeTime      String  @default("07:00")
  sleepTime     String  @default("23:00")
  breakfastTime String  @default("08:00")
  lunchTime     String  @default("13:00")
  dinnerTime    String  @default("19:30")
  trainingDays  String  @default("")
  routineNotes  String  @default("")

  waterBaseMl   Int     @default(0)
  waterTargetMl Int     @default(0)
  waterStreak   Int     @default(0)
  waterLastEval String  @default("")
  onboardingCompleted Boolean @default(false)

  updatedAt     DateTime @updatedAt
}

model Meal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD (user-local day)
  name      String
  type      MealType
  calories  Int      @default(0)
  protein   Int      @default(0)
  carbs     Int      @default(0)
  fat       Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  amountMl  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  weightKg  Float
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Habit {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  logs      HabitLog[]
}

model HabitLog {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitId String
  habit   Habit   @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date    String
  done    Boolean @default(false)

  @@unique([habitId, date])
  @@index([userId, date])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // "user" | "coach"
  text      String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Audit trail — every edit to changeable data is timestamped here
model ChangeHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  field     String
  fromValue String
  toValue   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
